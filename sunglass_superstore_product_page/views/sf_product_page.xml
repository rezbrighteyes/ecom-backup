<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="ss_stock_urgency"
              inherit_id="website_sale.product"
              name="SS: Stock Urgency"
              priority="25">
        <xpath expr="//div[@id='o_wsale_cta_wrapper']" position="after">
            <t t-set="stock_msg" t-value="product._sf_get_stock_message()"/>
            <div t-if="stock_msg" class="sf-stock-urgency mt-2 mb-2">
                <span class="badge bg-warning text-dark">
                    <i class="fa fa-fire me-1"/>
                    <t t-out="stock_msg"/>
                </span>
            </div>
        </xpath>
    </template>

    <template id="ss_trust_badges"
              inherit_id="website_sale.product"
              name="SS: Trust Badges"
              priority="25">
        <xpath expr="//div[@id='o_product_terms_and_share']" position="before">
            <div class="sf-trust-row my-3">
                <t t-set="ship_threshold" t-value="product._sf_get_shipping_threshold()"/>
                <div class="row g-2">
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <i class="fa fa-truck mb-1 d-block" style="font-size: 18px; color: #1D9E75;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">Free shipping over $<t t-out="ship_threshold"/></small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <i class="fa fa-refresh mb-1 d-block" style="font-size: 18px; color: #378ADD;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">30-day returns</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <t t-set="sf_qty" t-value="product._sf_get_stock_qty()"/>
                            <i t-if="sf_qty &gt; 0" class="fa fa-check-circle mb-1 d-block" style="font-size: 18px; color: #1D9E75;"/>
                            <i t-else="" class="fa fa-times-circle mb-1 d-block" style="font-size: 18px; color: #E24B4A;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">
                                <t t-if="sf_qty &gt; 0">In stock</t>
                                <t t-else="">Out of stock</t>
                            </small>
                        </div>
                    </div>
                </div>
                <t t-set="sf_qty_check" t-value="product._sf_get_stock_qty()"/>
                <div t-if="sf_qty_check &gt; 0" class="sf-delivery-estimate mt-2 p-2 rounded bg-light text-center">
                    <small class="text-muted">
                        <i class="fa fa-calendar-check-o me-1"/>
                        Estimated delivery: <strong class="text-dark"><t t-out="product._sf_get_delivery_date()"/></strong>
                    </small>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Inject cross-sells AFTER the accordion block that templates.xml emits.
         product_full_description no longer exists — accordion replaced it. -->
    <template id="ss_product_description_crosssells"
              inherit_id="sunglass_superstore_product_page.product_accordion_custom"
              name="SS: Cross-Sells Sidebar"
              priority="25">
        <xpath expr="//div[@id='product_accordion']" position="after">
            <t t-set="cross_sells" t-value="product._sf_get_cross_sells(4)"/>
            <t t-if="cross_sells">
                <section class="sf-crosssells-section container my-4">
                    <div class="sf-details-grid">
                        <div/>
                        <aside class="sf-sidebar" id="sf_sidebar">
                            <h3 class="sf-sidebar-title">You might also like</h3>
                            <div class="sf-related-list">
                                <t t-foreach="cross_sells" t-as="item">
                                    <t t-set="first_variant" t-value="item.product_variant_ids[:1]"/>
                                    <t t-if="first_variant">
                                        <div class="sf-related-item"
                                             t-att-data-product-id="first_variant.id"
                                             t-att-data-name="item.name"
                                             t-att-data-price="'$%.2f' % item.list_price">
                                            <a t-att-href="item.website_url" class="sf-related-link">
                                                <img t-att-src="'/web/image/product.template/%s/image_128' % item.id"
                                                     class="sf-related-thumb"
                                                     t-att-alt="item.name"
                                                     loading="lazy"/>
                                                <div class="sf-related-info">
                                                    <div class="sf-related-name" t-esc="item.name"/>
                                                    <div class="sf-related-price" t-if="item.list_price">
                                                        $<t t-esc="'%.2f' % item.list_price"/>
                                                    </div>
                                                </div>
                                            </a>
                                            <button type="button" class="sf-add-cart"
                                                    t-att-data-variant-id="first_variant.id"
                                                    title="Add to cart">
                                                <i class="fa fa-shopping-cart"/>
                                            </button>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </aside>
                    </div>
                </section>
            </t>
        </xpath>
    </template>

</odoo>
