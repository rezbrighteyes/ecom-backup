<odoo>
    <data>
        <record id='payment_provider_form_inherit_sale_credit_limit_extended' model='ir.ui.view'>
            <field name='name'>payment.provider.form.inherit.sale.credit.limit.extended</field>
            <field name='model'>payment.provider</field>
            <field name="inherit_id" ref="payment.payment_provider_form"/>
            <field name='arch' type='xml'>
                <xpath expr="//group[@name='availability']" position="inside">
                    <field name="hide_payment_if_over_credit"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>