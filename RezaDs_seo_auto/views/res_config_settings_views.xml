<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_seo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.seo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='website']" position="inside">
                <block title="Smart SEO — by Reza D Shiraz" id="smart_seo_settings">
                    <setting string="Meta Title Template" help="Template for auto-generated SEO titles. Use the product name placeholder.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3" string="Template" for="seo_meta_title_template"/>
                                <field name="seo_meta_title_template" placeholder="Product Name | Buy Online"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Default Brand Name" help="Fallback brand for Schema.org when product has no brand set.">
                        <div class="content-group">
                            <div class="row mt8">
                                <label class="col-lg-3" string="Brand" for="seo_default_brand"/>
                                <field name="seo_default_brand" placeholder="My Store Name"/>
                            </div>
                        </div>
                    </setting>
                    <setting id="seo_schema_setting" string="Product Schema" help="Inject Product JSON-LD for Google rich results with price, stock, and brand.">
                        <field name="seo_enable_schema"/>
                    </setting>
                    <setting id="seo_breadcrumb_setting" string="Breadcrumb Schema" help="Inject BreadcrumbList JSON-LD for navigation path in search results.">
                        <field name="seo_enable_breadcrumbs"/>
                    </setting>
                    <setting id="seo_noindex_setting" string="Auto Noindex" help="Add noindex on unpublished or inactive products to save crawl budget.">
                        <field name="seo_enable_noindex"/>
                    </setting>
                    <setting id="seo_title_setting" string="Auto SEO Title" help="Generate SEO title when a product is created or renamed.">
                        <field name="seo_enable_auto_title"/>
                    </setting>
                    <setting id="seo_slug_setting" string="Auto URL Slug" help="Generate clean slugs with stop words removed.">
                        <field name="seo_enable_auto_slug"/>
                    </setting>
                    <setting id="seo_desc_setting" string="Auto Meta Description" help="Extract meta description from eCommerce description.">
                        <field name="seo_enable_auto_description"/>
                    </setting>
                    <setting id="seo_keywords_setting" string="Auto Meta Keywords" help="Build keywords from brand, category, tags, and product name.">
                        <field name="seo_enable_auto_keywords"/>
                    </setting>
                    <setting id="seo_alt_setting" string="Auto Image Alt Text" help="Set image alt text using product name and brand.">
                        <field name="seo_enable_auto_image_alt"/>
                    </setting>
                    <setting id="seo_redirect_setting" string="301 Redirects" help="Auto-create redirects when product URL slug changes.">
                        <field name="seo_enable_redirects"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
