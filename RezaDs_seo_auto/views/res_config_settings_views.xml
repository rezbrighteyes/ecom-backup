<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_seo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.seo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='google_analytics_setting']" position="before">
                <block title="RezaDs SEO — by Reza D Shiraz" name="seo_settings">
                    <setting string="Meta Title Template" help="Use %(name)s for product name. Example: %(name)s | Buy Online">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="seo_meta_title_template" class="col-lg-3 o_light_label"/>
                                <field name="seo_meta_title_template" class="col-lg-6"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Default Brand Name" help="Fallback brand for Schema.org when product has no brand set.">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="seo_default_brand" class="col-lg-3 o_light_label"/>
                                <field name="seo_default_brand" class="col-lg-6"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Product Schema" help="Inject Product JSON-LD for Google rich results.">
                        <field name="seo_enable_schema"/>
                    </setting>
                    <setting string="Breadcrumb Schema" help="Inject BreadcrumbList JSON-LD.">
                        <field name="seo_enable_breadcrumbs"/>
                    </setting>
                    <setting string="Auto Noindex" help="Add noindex on unpublished or inactive products.">
                        <field name="seo_enable_noindex"/>
                    </setting>
                    <setting string="Auto SEO Title" help="Auto-generate title on product create/rename.">
                        <field name="seo_enable_auto_title"/>
                    </setting>
                    <setting string="Auto URL Slug" help="Auto-generate clean URL slug.">
                        <field name="seo_enable_auto_slug"/>
                    </setting>
                    <setting string="Auto Meta Description" help="Auto-generate from eCommerce description.">
                        <field name="seo_enable_auto_description"/>
                    </setting>
                    <setting string="Auto Keywords" help="Auto-generate from brand, category, tags.">
                        <field name="seo_enable_auto_keywords"/>
                    </setting>
                    <setting string="Auto Image Alt Text" help="Auto-set alt text using product name.">
                        <field name="seo_enable_auto_image_alt"/>
                    </setting>
                    <setting string="301 Redirects" help="Auto-create redirects when URL slug changes.">
                        <field name="seo_enable_redirects"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
