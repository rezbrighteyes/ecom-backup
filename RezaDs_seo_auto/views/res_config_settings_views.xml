<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_seo" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.seo</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <block title="RezaDs SEO — by Reza D Shiraz" name="seo_settings">
                    <setting string="Meta Title Template">
                        <field name="seo_meta_title_template"/>
                    </setting>
                    <setting string="Default Brand Name">
                        <field name="seo_default_brand"/>
                    </setting>
                    <setting string="Product Schema">
                        <field name="seo_enable_schema"/>
                    </setting>
                    <setting string="Breadcrumb Schema">
                        <field name="seo_enable_breadcrumbs"/>
                    </setting>
                    <setting string="Auto Noindex">
                        <field name="seo_enable_noindex"/>
                    </setting>
                    <setting string="Auto SEO Title">
                        <field name="seo_enable_auto_title"/>
                    </setting>
                    <setting string="Auto URL Slug">
                        <field name="seo_enable_auto_slug"/>
                    </setting>
                    <setting string="Auto Meta Description">
                        <field name="seo_enable_auto_description"/>
                    </setting>
                    <setting string="Auto Keywords">
                        <field name="seo_enable_auto_keywords"/>
                    </setting>
                    <setting string="Auto Image Alt Text">
                        <field name="seo_enable_auto_image_alt"/>
                    </setting>
                    <setting string="301 Redirects">
                        <field name="seo_enable_redirects"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
