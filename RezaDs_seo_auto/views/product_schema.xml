<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_schema_jsonld"
              inherit_id="website_sale.product"
              name="RezaDs SEO - Schema.org JSON-LD">
        <xpath expr="//head" position="inside">
            <t t-if="product">
                <script type="application/ld+json" t-out="product.get_schema_jsonld(website.name)"/>
            </t>
        </xpath>
    </template>
</odoo>
