<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_purchase_buttons_from_variant_extended" model="ir.ui.view">
        <field name="name">product.template.purchase.button.inherit.variant.extended</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='variants']//field[@name='attribute_line_ids']/list/field[last()]" position="after">
                <field name="show_in_website" />
            </xpath>
        </field>
    </record>
</odoo>
