<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_import_product_images_wizard" model="ir.ui.view">
        <field name="name">import.product.images.wizard</field>
        <field name="model">import.product.images</field>
        <field name="arch" type="xml">
            <form string="Import Product Images">
                <group>
                    <field name="excel_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_product_images" model="ir.actions.act_window">
        <field name="name">Import Product Images</field>
        <field name="res_model">import.product.images</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_import_product_images" name="Import Product Images"
              parent="product.menu_catalog"
              action="action_import_product_images"/>
</odoo>
