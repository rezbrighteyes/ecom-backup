    <record id="view_choose_delivery_carrier_form_starshipit" model="ir.ui.view">
        <field name="name">choose.delivery.carreir.view.starshipit</field>
        <field name="model">choose.delivery.carrier</field>
        <field name="inherit_id" ref="delivery.choose_delivery_carrier_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form[last()]" position="inside">
                <div>
                    <field name="starshipit_rates_ids" invisible="delivery_type != 'starshipit' or not starshipit_rates_ids">
                        <list create="false" edit="false" delete="false">
                            <field name="service_code" readonly="1"/>
                            <field name="service_name" readonly="1"/>
                            <field name="service_price" readonly="1"/>
                            <button name="add_selected_starshipit_rate"  string="Select" type='object'  class='btn btn-primary'/>
                        </list>
                    </field>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
