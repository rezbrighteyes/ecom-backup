<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="d3_standard_improvements.brand_promotion_message" inherit_id="web.brand_promotion_message">
        <xpath expr="//t[@t-set='odoo_logo']" position="replace">
            <t t-set="odoo_logo">
                <a target="_blank" t-attf-href="http://www.ecomsuperstore.com.au" class="badge text-bg-light" rel="nofollow">
                    <img alt="E-com Superstore" src="/d3_standard_improvements/static/img/ecom_logo_tiny.png" width="62" height="20" style="width: auto; height: 1em; vertical-align: baseline;"/>
                    E-com Superstore
                </a>
            </t>
        </xpath>
        <xpath expr="//t[@t-set='final_message']" position="replace">
            <t t-set="final_message">Powered by %s%s</t>
        </xpath>
    </template>
</odoo>