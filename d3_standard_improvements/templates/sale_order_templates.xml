<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="d3_standard_improvements.report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_image" class="text-start" t-if="doc.report_product_image">Image</th>
        </xpath>
        <xpath expr="//td[@name='td_name']" position="before">
            <td name="td_image" t-if="doc.report_product_image">
                <!-- <span t-field="line.product_id.image_128" t-options="{'widget': 'image', 'max_width': '64', 'class': 'rounded'}" /> -->
                <!-- <span t-field="line.product_id.image_128" t-options="{'widget': 'image', 'qweb_img_responsive': False, 'class': 'o_image_64_max rounded'}"/> -->
                <img t-if="line.product_id.image_128" t-att-src="image_data_uri(line.product_id.image_128)" class="o_image_64_max img rounded" t-att-alt="line.name" />
                <!-- <div t-elif="line.product_id.image_128" t-field="line.product_id.image_128" t-options="{ 'widget': 'image', 'qweb_img_responsive': False, 'class': 'o_image_64_max rounded'}" /> -->
            </td>
        </xpath>
    </template>

    <template id="d3_standard_improvements.report_saleorder_document_inherit_sale_management" inherit_id="sale_management.report_saleorder_document_inherit_sale_management">
        <xpath expr="//td[@name='th_option_name']" position="before">
            <td name="th_option_image" class="text-start" t-if="doc.report_product_image">Image</td>
        </xpath>
        <xpath expr="//td[@name='td_option_name']" position="before">
            <td name="td_option_image" t-if="doc.report_product_image">
                <img t-if="option.product_id.image_128" t-att-src="image_data_uri(option.product_id.image_128)" class="o_image_64_max img rounded" t-att-alt="option.name" />
            </td>
        </xpath>
    </template>

    <template id="d3_standard_improvements.sale_order_portal_content" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//th[@id='product_name_header']" position="before">
            <th class="text-start" id="product_name_image" t-if="sale_order.report_product_image">Images</th>
        </xpath>
        <xpath expr="//td[@id='product_name']" position="before">
            <td id="product_image" t-if="sale_order.report_product_image">
                <img t-if="line.product_id.image_128" t-att-src="image_data_uri(line.product_id.image_128)" class="o_image_64_max img rounded" t-att-alt="line.name" />
            </td>
        </xpath>
    </template>

    <template id="d3_standard_improvements.sale_order_portal_content_inherit_sale_management" inherit_id="sale_management.sale_order_portal_content_inherit_sale_management">
        <xpath expr="//th[@name='th_option_product_name']" position="before">
            <th class="text-start" name="th_option_product_name" t-if="sale_order.report_product_image">Image</th>
        </xpath>
        <xpath expr="//td[@name='td_option_product_name']" position="before">
            <td name="td_option_product_image" t-if="sale_order.report_product_image">
                <img t-if="option.product_id.image_128" t-att-src="image_data_uri(option.product_id.image_128)" class="o_image_64_max img rounded" t-att-alt="option.name" />
            </td>
        </xpath>
    </template>
</odoo>