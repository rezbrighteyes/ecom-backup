<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="d3_standard_improvements.brand_promotion" inherit_id="website.brand_promotion">
        <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            <t t-call="web.brand_promotion_message">
                <t t-set="_message"></t>
                <t t-set="_utm_medium"></t>
            </t>
        </xpath>
    </template>

    <template id="d3_standard_improvements.product_price" inherit_id="website_sale.product_price">
        <xpath expr="//span[@itemprop='listPrice']" position="attributes">
            <attribute name="itemprop" remove="listPrice" add="priceSpecification" separator=" "/>
            <!-- <attribute name="itemprop">priceSpecification</attribute> -->
        </xpath>
    </template>
</odoo>