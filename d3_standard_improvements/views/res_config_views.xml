<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_sale" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='sale_management']" position="inside">
                <block title="Report Product Image">
                    <setting id="product_image" string="Print Product Image" help="Show the image product on sale report.">
                        <field name="report_product_image" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="res_config_settings_view_form_mrp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//app[@name='mrp']" position="inside">
                <block title="Work Center Cost">
                    <setting id="operation_cost" string="Active Operation Costs" help="Create an accounting entry for operation costs">
                        <field name="work_center_cost" />
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>