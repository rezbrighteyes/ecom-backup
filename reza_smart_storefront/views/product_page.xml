<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="stock_urgency" inherit_id="website_sale.product" name="Smart Storefront - Stock Urgency">
        <xpath expr="//div[@id='o_wsale_cta_wrapper']" position="after">
            <t t-set="stock_msg" t-value="product._sf_get_stock_message()"/>
            <div t-if="stock_msg" class="sf-stock-urgency mt-2 mb-2">
                <span class="badge bg-warning text-dark">
                    <i class="fa fa-fire me-1"/>
                    <t t-out="stock_msg"/>
                </span>
            </div>
        </xpath>
    </template>

    <template id="trust_badges" inherit_id="website_sale.product" name="Smart Storefront - Trust Badges">
        <xpath expr="//div[@id='o_product_terms_and_share']" position="before">
            <div class="sf-trust-row my-3">
                <div class="row g-2">
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <i class="fa fa-truck mb-1 d-block" style="font-size: 18px; color: #1D9E75;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">Free shipping over $50</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <i class="fa fa-refresh mb-1 d-block" style="font-size: 18px; color: #378ADD;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">30-day returns</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="sf-trust-badge text-center p-2 rounded bg-light">
                            <t t-set="sf_qty" t-value="product._sf_get_stock_qty()"/>
                            <i t-if="sf_qty > 0" class="fa fa-check-circle mb-1 d-block" style="font-size: 18px; color: #1D9E75;"/>
                            <i t-else="" class="fa fa-times-circle mb-1 d-block" style="font-size: 18px; color: #E24B4A;"/>
                            <small class="text-muted d-block" style="font-size: 11px; line-height: 1.3;">
                                <t t-if="sf_qty > 0">In stock</t>
                                <t t-else="">Out of stock</t>
                            </small>
                        </div>
                    </div>
                </div>
                <t t-set="sf_qty_check" t-value="product._sf_get_stock_qty()"/>
                <div t-if="sf_qty_check > 0" class="sf-delivery-estimate mt-2 p-2 rounded bg-light text-center">
                    <small class="text-muted">
                        <i class="fa fa-calendar-check-o me-1"/>
                        Estimated delivery: <strong class="text-dark"><t t-out="product._sf_get_delivery_date()"/></strong>
                    </small>
                </div>
            </div>
        </xpath>
    </template>

    <template id="smart_cross_sells" inherit_id="website_sale.product" name="Smart Storefront - Cross Sells">
        <xpath expr="//div[@id='oe_structure_website_sale_product_2']" position="after">
            <t t-set="cross_sells" t-value="product._sf_get_cross_sells(4)"/>
            <section t-if="cross_sells" class="container my-4">
                <h5 class="mb-3">You might also like</h5>
                <div class="row g-3">
                    <t t-foreach="cross_sells" t-as="cs_product">
                        <div class="col-6 col-md-3">
                            <a t-att-href="'/shop/%s' % (cs_product.seo_name or cs_product.id)" class="text-decoration-none">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px; overflow: hidden;">
                                        <img t-att-src="'/web/image/product.template/%s/image_256' % cs_product.id"
                                             t-att-alt="cs_product.name"
                                             class="img-fluid"
                                             style="max-height: 150px; object-fit: contain;"
                                             loading="lazy"/>
                                    </div>
                                    <div class="card-body p-2">
                                        <p class="mb-1 text-dark small fw-bold text-truncate" t-out="cs_product.name"/>
                                        <p class="mb-0 text-primary fw-bold">
                                            $<t t-out="'%.2f' % cs_product.list_price"/>
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </t>
                </div>
            </section>
        </xpath>
    </template>
</odoo>
