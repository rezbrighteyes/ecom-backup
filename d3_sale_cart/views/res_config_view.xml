<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_marketing_automation']" position="after">
                <setting string="Create coupon when sending abandoned checkout emails"
                    help="When enabled, a coupon will be automatically created and sent to the customer with the abandoned checkout email. The coupon will be valid for the number of days defined below, starting from the creation date.">
                    <!-- Activar/desactivar creación de cupones -->
                    <field name="create_coupon_abandoned_cart_email" />
                    <!-- Configuración extra -->
                    <div invisible="not create_coupon_abandoned_cart_email" class="content-group">

                        <!-- Selección del programa -->
                        <div class="row mt16">
                            <div class="col-12">
                                <label for="program_coupon_abandoned_cart_email"
                                    string="Coupon Program" class="o_light_label" />
                                <field name="program_coupon_abandoned_cart_email" class="col-6"
                                    options="{'no_create': False}" required="create_coupon_abandoned_cart_email" />
                            </div>
                        </div>

                        <!-- Días de validez -->
                        <div class="row mt8">
                            <div class="col-12">
                                <label for="days_coupon_abandoned_cart_email"
                                    string="Coupon Validity (Days)" class="o_light_label" />
                                <field name="days_coupon_abandoned_cart_email" class="col-2"
                                    placeholder="e.g. 7" />
                                <span class="text-muted">Days after creation until the coupon
                                    expires</span>
                            </div>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>