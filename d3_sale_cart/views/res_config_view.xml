<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_marketing_automation']" position="after">
                <setting string="Create coupon on send abandoned checkout emails"
                    invisible="not send_abandoned_cart_email"
                    help="Automatically creation of coupons on send abandoned checjout emails.">
                    <field name="create_coupon_abandoned_cart_email" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>