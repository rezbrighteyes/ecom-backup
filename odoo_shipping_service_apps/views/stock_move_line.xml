    <record id="view_stock_move_line_tree_inherit" model="ir.ui.view">
        <field name="name">stock.move.line.tree.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='result_package_id' and @groups='stock.group_tracking_lot']"
                position="attributes">
                <attribute name="domain">[('id', 'in', related_package_ids)]</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_stock_move_line_form_inherit" model="ir.ui.view">
        <field name="name">stock.move.line.form.inherit</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form" /> <!-- This is the form view -->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='result_package_id' and @groups='stock.group_tracking_lot']"
                position="attributes">
                <attribute name="domain">[('id', 'in', related_package_ids)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>