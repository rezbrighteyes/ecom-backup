<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ViewContent on product page -->
    <template id="product_pixel" inherit_id="website_sale.product">
        <xpath expr="//div[@id='product_detail']" position="before">
            <script type="text/javascript">
                fbq('track', 'ViewContent', {
                    content_ids: ['<t t-esc="product.id"/>'],
                    content_name: '<t t-esc="product.name"/>',
                    content_type: 'product',
                    value: <t t-esc="product.list_price"/>,
                    currency: '<t t-esc="website.currency_id.name"/>'
                });
            </script>
        </xpath>
    </template>

    <!-- Purchase on confirmation page -->
    <template id="confirmation_pixel" inherit_id="website_sale.confirmation">
        <xpath expr="//div[@id='o_website_sale_free_carrier']" position="before">
            <t t-if="order">
                <script type="text/javascript">
                    fbq('track', 'Purchase', {
                        value: <t t-esc="order.amount_total"/>,
                        currency: '<t t-esc="order.currency_id.name"/>',
                        content_ids: [<t t-foreach="order.order_line" t-as="line">'<t t-esc="line.product_id.id"/>',</t>],
                        content_type: 'product'
                    });
                </script>
            </t>
        </xpath>
    </template>
</odoo>
