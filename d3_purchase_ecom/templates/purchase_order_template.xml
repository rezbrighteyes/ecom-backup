<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="d3_purchase_ecom" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//table[hasclass('table')]" position="inside">
            <tr>
                <td>
                    <span>
                        Total Lines: 
                        <span t-esc="len(o.order_line.filtered(lambda l: not l.display_type))"/>
                    </span>
                </td>
                <td>
                    <span>
                        Total Qty: 
                        <span t-esc="sum(o.order_line.mapped('product_qty'))"/>
                    </span>
                </td>
            </tr>
        </xpath>
    </template>
</odoo>